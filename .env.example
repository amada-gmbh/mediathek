# Broschüren-Mediathek – Umgebungsvariablen v1.3.1
# Kopie als .env anlegen und anpassen

MEDIATHEK_PORT=8091

# --- Branding (Kiosk-UI) ---
COMPANY_NAME=AMADA
# Lokaler Pfad (/assets/...) oder https:// URL
COMPANY_LOGO_URL=https://cdn.amada.eu/typo3conf/ext/theme/Resources/Public/images/logo-80th.png

# --- Crawl-Quelle (öffentliche Website) ---
# Beispiel AMADA EU:
SOURCE_BASE_URL=https://www.amada.eu
# Leer lassen (z. B. INDEX_FR=) = Sprache wird übersprungen:
# kein Crawl, kein PDF-Download, nicht in der UI.
INDEX_DE=de-de/produkte/broschueren-mediathek/
INDEX_EN=de-en/products/amada-brochures-library/
INDEX_NL=nl-nl/producten/brochure-bibliotheek/
INDEX_FR=fr-fr/produits/bibliotheque-de-brochures/
INDEX_IT=it-it/prodotti/archivio-brochure/
INDEX_PL=pl-pl/produkty/biblioteka-broszur/
INDEX_HU=hu-hu/termekek/kiadvany-koenyvtar/
INDEX_RO=ro-ro/produse/biblioteca-de-brosuri/
INDEX_SE=se-se/produkter/broschyr-mediabibliotek/
INDEX_TR=tr-tr/ueruenler/brosuer-kuetuephanesi/

# Sync / PDF-Download
SYNC_ENABLED=true
SYNC_ON_START=true
SYNC_INTERVAL_HOURS=24
SYNC_TIMEOUT_SECONDS=3600
# SYNC_ON_START=true → Sync nur wenn noch kein Manifest (Volumes leer). Sonst nur Cron.
# Einmalig erzwingen: SYNC_FORCE=true

# SYNC_FORCE=true → Quellen neu crawlen + Manifest/Thumbnails aktualisieren (kein PDF-Neudownload)
# SYNC_FORCE=true

# SYNC_FORCE_DOWNLOAD=true → zusätzlich alle PDFs neu laden (nur einmalig nötig, danach false)
# SYNC_FORCE_DOWNLOAD=true

# Sicherheit: Crawl nur öffentliche Hosts (Standard). Für interne Quellen:
# SYNC_ALLOW_PRIVATE_HOSTS=true
# SYNC_MAX_PDF_BYTES=104857600

# Screensaver – standardmäßig AUS (leere URL oder SCREENSAVER_ENABLED=false)
# SCREENSAVER_ENABLED=false
# SCREENSAVER_TIMEOUT_MINUTES=5
# SCREENSAVER_VIDEO_URL=
# Aktivieren: SCREENSAVER_ENABLED=true und z. B. SCREENSAVER_VIDEO_URL=/assets/screensaver.mp4
# (Video vorher nach frontend/assets/ legen und Image neu bauen, oder eigenen Pfad setzen)

# PDF-Ansicht: single (eine Seite) | double (Doppelseite)
PDF_PAGE_MODE=single

# Dedicated Touchscreen: true = kompaktes Hochformat-Layout (wenn Windows im Querformat läuft)
# KIOSK_TOUCH_LAYOUT=true

# Legacy (weiterhin unterstützt): AMADA_BASE_URL, AMADA_INDEX_*
